# IHP PDK environment — copy to ihp_pdk.env and adjust for your system.
#
# IIC-OSIC-TOOLS container (tested):
#   PDK_ROOT=/foss/pdks
#   PATH prefix: /foss/tools/bin:/foss/tools/sak
#
# Generic installation: set PDK_ROOT to the directory that contains
# the ihp-sg13g2/ subdirectory cloned from IHP-Open-PDK.

export PDK_ROOT=/foss/pdks
export PDK=ihp-sg13g2

# Prepend tool binaries to PATH so that bash -lc invocations in the
# LibreLane Makefile can find yosys, openroad, klayout, etc.
export PATH=/foss/tools/bin:/foss/tools/sak:${PATH}
