# IHP PDK environment example
# Copy this file to ihp_pdk.env and update the paths to your local IHP PDK installation.

export PDK_ROOT=/opt/ihp
export PDK=ihp-sg13g2
export IHP_PDK_ROOT=${PDK_ROOT}
export IHP_CELL_LEF=${IHP_PDK_ROOT}/lef/ihp130_stdcell.lef
export IHP_TECH_LEF=${IHP_PDK_ROOT}/lef/ihp130_tech.lef
export IHP_STD_CELL_LIB=${IHP_PDK_ROOT}/lib/ihp130_stdcell.lib
export IHP_IO_LEF=${IHP_PDK_ROOT}/lef/ihp130_io.lef
export IHP_IO_LIB=${IHP_PDK_ROOT}/lib/ihp130_io.lib
export IHP_PAD_RING_LEF=${IHP_PDK_ROOT}/lef/ihp130_padring.lef
